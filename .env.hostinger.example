# Hostinger Email Configuration
# Copy this to your .env file and update with your values

# Email Settings for Hostinger
MAIL_FROM_ADDRESS=noreply@athletesgym.qa
MAIL_FROM_NAME="Athletes Gym Qatar"
MAIL_REPLY_TO=info@athletesgym.qa
MAIL_ADMIN_ADDRESS=admin@athletesgym.qa

# Application URL
APP_URL=https://athletesgym.qa

# Note: Hostinger uses PHP mail() function by default
# The email will be sent from the domain's email address configured in cPanel
# Make sure your domain has proper SPF and DKIM records set up in Hostinger cPanel
